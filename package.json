{
  "name": "bilig",
  "version": "0.1.0",
  "private": true,
  "description": "Production spreadsheet engine monorepo with worker-first web app, custom reconciler, and AssemblyScript/WASM fast path.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm dev:web-local",
    "dev:web": "pnpm --filter @bilig/web dev",
    "dev:local": "BILIG_RUN_DATA_MIGRATIONS_ON_BOOT=true pnpm --filter @bilig/app dev",
    "dev:web-local": "bun scripts/run-dev-web-local.ts",
    "dev:sync": "BILIG_RUN_DATA_MIGRATIONS_ON_BOOT=true pnpm --filter @bilig/app dev",
    "docker:build:app": "docker buildx build --load --target bilig-runtime -t registry.ide-newton.ts.net/lab/bilig-app:${BILIG_IMAGE_TAG:-local} .",
    "docker:publish:app": "docker buildx build --platform ${BILIG_IMAGE_PLATFORMS:-linux/amd64,linux/arm64} --provenance=false --sbom=false --push --target bilig-runtime -t registry.ide-newton.ts.net/lab/bilig-app:${BILIG_IMAGE_TAG:-local} .",
    "protocol:generate": "bun scripts/gen-protocol.ts",
    "protocol:check": "bun scripts/gen-protocol.ts --check",
    "formula-inventory:generate": "bun scripts/gen-formula-inventory.ts",
    "formula-inventory:check": "bun scripts/gen-formula-inventory.ts --check",
    "formula:dominance:generate": "bun scripts/gen-formula-dominance-snapshot.ts",
    "formula:dominance:check": "bun scripts/gen-formula-dominance-snapshot.ts --check",
    "calculation:semantics:generate": "bun scripts/gen-calculation-semantics-scorecard.ts",
    "calculation:semantics:check": "bun scripts/gen-calculation-semantics-scorecard.ts --check",
    "calculation:excel-live:generate": "bun scripts/gen-microsoft-excel-live-calculation-scorecard.ts",
    "calculation:excel-live:check": "bun scripts/gen-microsoft-excel-live-calculation-scorecard.ts --check",
    "calculation:google-sheets-live:check": "bun scripts/gen-google-sheets-live-calculation-scorecard.ts --check",
    "recalculation:excel-live:generate": "bun scripts/gen-microsoft-excel-live-recalculation-scorecard.ts",
    "recalculation:excel-live:check": "bun scripts/gen-microsoft-excel-live-recalculation-scorecard.ts --check",
    "recalculation:google-sheets-live:generate": "bun scripts/gen-google-sheets-live-recalculation-scorecard.ts",
    "recalculation:google-sheets-live:check": "bun scripts/gen-google-sheets-live-recalculation-scorecard.ts --check",
    "structural:excel-live:generate": "bun scripts/gen-microsoft-excel-live-structural-scorecard.ts",
    "structural:excel-live:check": "bun scripts/gen-microsoft-excel-live-structural-scorecard.ts --check",
    "structural:google-sheets-live:generate": "bun scripts/gen-google-sheets-live-structural-scorecard.ts",
    "structural:google-sheets-live:check": "bun scripts/gen-google-sheets-live-structural-scorecard.ts --check",
    "large-workbook:excel-live:generate": "bun scripts/gen-microsoft-excel-live-large-workbook-scorecard.ts",
    "large-workbook:excel-live:check": "bun scripts/gen-microsoft-excel-live-large-workbook-scorecard.ts --check",
    "large-workbook:google-sheets-live:generate": "bun scripts/gen-google-sheets-live-large-workbook-scorecard.ts",
    "large-workbook:google-sheets-live:check": "bun scripts/gen-google-sheets-live-large-workbook-scorecard.ts --check",
    "auditability:generate": "bun scripts/gen-auditability-scorecard.ts",
    "auditability:check": "bun scripts/gen-auditability-scorecard.ts --check",
    "reliability:generate": "bun scripts/gen-reliability-scorecard.ts",
    "reliability:check": "bun scripts/gen-reliability-scorecard.ts --check",
    "collaboration:generate": "bun scripts/gen-collaboration-scorecard.ts",
    "collaboration:check": "bun scripts/gen-collaboration-scorecard.ts --check",
    "automation:generate": "bun scripts/gen-automation-scorecard.ts",
    "automation:check": "bun scripts/gen-automation-scorecard.ts --check",
    "import-export:fidelity:generate": "bun scripts/gen-import-export-fidelity-scorecard.ts",
    "import-export:fidelity:check": "bun scripts/gen-import-export-fidelity-scorecard.ts --check",
    "public-workbook-corpus:init": "bun scripts/public-workbook-corpus.ts init",
    "public-workbook-corpus:discover": "bun scripts/public-workbook-corpus.ts discover-ckan",
    "public-workbook-corpus:discover-financial": "bun scripts/public-workbook-corpus.ts discover-financial-ckan --manifest .cache/public-workbook-corpus-financial/manifest.json --cache-dir .cache/public-workbook-corpus-financial --target-workbook-count 5000 --limit 15000",
    "public-workbook-corpus:fetch": "bun scripts/public-workbook-corpus.ts fetch",
    "public-workbook-corpus:fetch-financial": "bun scripts/public-workbook-corpus.ts fetch --manifest .cache/public-workbook-corpus-financial/manifest.json --cache-dir .cache/public-workbook-corpus-financial --limit 5000 --max-bytes 52428800",
    "public-workbook-corpus:verify": "bun scripts/public-workbook-corpus.ts verify",
    "public-workbook-corpus:verify-financial": "bun scripts/public-workbook-corpus.ts verify --manifest .cache/public-workbook-corpus-financial/manifest.json --cache-dir .cache/public-workbook-corpus-financial --scorecard .cache/public-workbook-corpus-financial/scorecard.json",
    "public-workbook-corpus:check": "bun scripts/public-workbook-corpus.ts check",
    "public-workbook-corpus:check-financial": "bun scripts/public-workbook-corpus.ts check --scorecard .cache/public-workbook-corpus-financial/scorecard.json --require-target",
    "large-workbook:slo:generate": "bun scripts/gen-large-workbook-slo-scorecard.ts",
    "large-workbook:slo:check": "bun scripts/gen-large-workbook-slo-scorecard.ts --check",
    "ui:same-corpus:capture": "bun scripts/capture-ui-responsiveness-same-corpus.ts",
    "ui:same-corpus:fixture:generate": "bun scripts/capture-ui-responsiveness-same-corpus.ts --emit-xlsx packages/benchmarks/baselines/ui-same-corpus",
    "ui:same-corpus:fixture:check": "bun scripts/capture-ui-responsiveness-same-corpus.ts --emit-xlsx packages/benchmarks/baselines/ui-same-corpus --check",
    "ui:browser-live:generate": "bun scripts/gen-ui-responsiveness-live-browser-scorecard.ts",
    "ui:browser-live:check": "bun scripts/gen-ui-responsiveness-live-browser-scorecard.ts --check",
    "security:posture:generate": "bun scripts/gen-security-posture-scorecard.ts",
    "security:posture:check": "bun scripts/gen-security-posture-scorecard.ts --check",
    "security:audit": "pnpm audit --prod",
    "dominance:generate": "bun scripts/gen-bilig-dominance-scorecard.ts",
    "dominance:check": "bun scripts/gen-bilig-dominance-scorecard.ts --check",
    "workspace-resolution:generate": "bun scripts/gen-workspace-resolution.ts",
    "workspace-resolution:check": "bun scripts/gen-workspace-resolution.ts --check",
    "zero:data-migrate": "bun scripts/run-zero-data-migrations.ts",
    "naming:check": "bun scripts/check-canonical-naming.ts",
    "docs:social-preview:generate": "tsx scripts/render-social-preview.ts",
    "docs:social-preview:check": "tsx scripts/render-social-preview.ts --check",
    "docs:launch-assets:generate": "tsx scripts/render-launch-assets.ts",
    "docs:launch-assets:check": "tsx scripts/render-launch-assets.ts --check",
    "docs:launch-demo:generate": "tsx scripts/render-launch-demo.ts",
    "docs:launch-demo:check": "tsx scripts/render-launch-demo.ts --check",
    "docs:discovery:check": "tsx scripts/check-docs-discovery.ts",
    "sheet:agent": "bun scripts/spreadsheet-agent.ts",
    "format": "oxfmt --write .oxlintrc.json package.json playwright.config.ts tsconfig.base.json tsconfig.json vitest.config.ts vitest.workspace.ts apps packages e2e scripts",
    "format:check": "oxfmt --check .oxlintrc.json package.json playwright.config.ts tsconfig.base.json tsconfig.json vitest.config.ts vitest.workspace.ts apps packages e2e scripts",
    "lint": "oxlint --config .oxlintrc.json --type-aware --deny-warnings packages apps e2e scripts",
    "lint:fix": "oxlint --config .oxlintrc.json --type-aware --fix packages apps e2e scripts",
    "analyze:dead-code": "knip --workspace apps/bilig --workspace apps/web --workspace packages/agent-api --workspace packages/core --workspace packages/formula --workspace packages/grid --workspace packages/runtime-kernel --workspace packages/worker-transport --include files,dependencies --no-progress",
    "analyze:exports": "knip --workspace apps/bilig --include exports --no-progress",
    "analyze:cycles": "depcruise --config .dependency-cruiser.cjs apps/bilig/src apps/web/src packages/agent-api/src packages/core/src packages/formula/src packages/grid/src packages/runtime-kernel/src packages/worker-transport/src",
    "source-size:check": "bun scripts/check-source-file-size.ts",
    "analyze:quality": "pnpm source-size:check && pnpm analyze:dead-code && pnpm analyze:exports && pnpm analyze:cycles",
    "hooks:pre-commit": "lint-staged",
    "hooks:pre-push": "pnpm lint",
    "prepare": "node scripts/install-git-hooks.mjs",
    "build": "pnpm workspace-resolution:generate && pnpm --filter @bilig/protocol build && pnpm --filter @bilig/workbook-domain build && pnpm --filter @bilig/binary-protocol build && pnpm --filter @bilig/agent-api build && pnpm --filter @bilig/contracts build && pnpm --filter @bilig/runtime-kernel build && pnpm --filter @bilig/actors build && pnpm --filter @bilig/formula build && pnpm --filter @bilig/storage-browser build && pnpm --filter @bilig/storage-server build && pnpm --filter @bilig/excel-fixtures build && pnpm --filter @bilig/excel-import build && pnpm --filter @bilig/wasm-kernel build && pnpm --filter @bilig/core build && pnpm --filter @bilig/headless build && pnpm --filter @bilig/worker-transport build && pnpm --filter @bilig/renderer build && pnpm --filter @bilig/grid build && pnpm --filter @bilig/benchmarks build && pnpm --filter @bilig/zero-sync build && pnpm --filter @bilig/app build && pnpm --filter @bilig/web build",
    "typecheck": "tsc -b --pretty false",
    "test": "bun scripts/run-vitest.ts --run",
    "coverage": "bun scripts/run-vitest.ts --run --coverage --exclude '**/*.fuzz.test.ts' --maxWorkers=1",
    "test:browser": "bun scripts/run-browser-tests.ts",
    "test:browser:full": "BILIG_BROWSER_INCLUDE_PERF=1 BILIG_BROWSER_INCLUDE_DEEP=1 BILIG_BROWSER_INCLUDE_FUZZ=1 BILIG_FUZZ_PROFILE=main BILIG_FUZZ_CAPTURE=1 bun scripts/run-browser-tests.ts",
    "test:browser:prod": "pnpm exec playwright test -c playwright.prod.config.ts e2e/tests/prod-smoke.pw.ts",
    "test:fuzz": "bun scripts/run-fuzz.ts default",
    "test:fuzz:main": "bun scripts/run-fuzz.ts main",
    "test:fuzz:nightly": "bun scripts/run-fuzz.ts nightly",
    "test:fuzz:replay": "bun scripts/run-fuzz.ts replay",
    "test:fuzz:promote": "bun scripts/promote-fuzz-artifact.ts",
    "test:correctness:core": "bun scripts/run-vitest.ts --run packages/core/src/__tests__/engine-correctness.test.ts packages/core/src/__tests__/engine-formula-initialization.test.ts packages/core/src/__tests__/mutation-service.test.ts packages/core/src/__tests__/workbook-store.test.ts packages/core/src/__tests__/engine-range-format-ops.test.ts packages/headless/src/__tests__/github-issues.test.ts packages/headless/src/__tests__/github-issue-54-hlookup-exact.test.ts packages/headless/src/__tests__/github-issue-62-choose-blank-reference.test.ts packages/headless/src/__tests__/github-issue-119-evaluation-timeout.test.ts packages/headless/src/__tests__/github-issue-122-workpaper-version.test.ts packages/headless/src/__tests__/github-issue-123-sum-formula-members.test.ts packages/headless/src/__tests__/github-issue-124-sumifs-wildcard-arithmetic.test.ts packages/headless/src/__tests__/github-issue-125-xlookup-decimal.test.ts scripts/__tests__/runtime-package-publish-validation.test.ts",
    "test:correctness:browser": "bun scripts/run-vitest.ts --run apps/web/src/__tests__/projected-viewport-store.test.ts apps/web/src/__tests__/workbook-changes.test.tsx apps/web/src/__tests__/workbook-editor-conflict.test.tsx apps/web/src/__tests__/worker-runtime-state.test.ts apps/web/src/__tests__/worker-workbook-app-model.test.ts apps/web/src/__tests__/worker-runtime-reconnect.test.ts apps/web/src/__tests__/worker-runtime.test.ts",
    "test:correctness:formula": "bun scripts/run-vitest.ts --run packages/formula/src/__tests__/fixture-harness.test.ts packages/formula/src/__tests__/lookup-exact-numeric.test.ts packages/core/src/__tests__/formula-runtime-correctness.test.ts packages/core/src/__tests__/hyperformula-smoke-parity.test.ts packages/wasm-kernel/src/__tests__/kernel-aggregate-criteria-dispatch.test.ts packages/wasm-kernel/src/__tests__/kernel-lookup-dispatch.test.ts",
    "test:correctness:corpus": "bun scripts/run-vitest.ts --run scripts/__tests__/public-workbook-corpus.test.ts scripts/__tests__/public-workbook-corpus-cli.test.ts scripts/__tests__/public-workbook-corpus-verify-checkpoint.test.ts scripts/__tests__/public-workbook-corpus-workbook.test.ts packages/excel-import/src/__tests__/excel-import.test.ts packages/excel-import/src/__tests__/excel-import-sparse-range.test.ts packages/excel-import/src/__tests__/xlsx-export-large-simple.test.ts packages/excel-import/src/__tests__/xlsx-sheet-name-whitespace.test.ts",
    "test:correctness:server": "bun scripts/run-vitest.ts --run apps/bilig/src/zero/__tests__/projection.test.ts apps/bilig/src/zero/__tests__/projection-parity.test.ts apps/bilig/src/zero/__tests__/sync-relay.test.ts apps/bilig/src/http/sync-server.test.ts apps/bilig/src/workbook-runtime/browser-sync-replay.test.ts apps/bilig/src/workbook-runtime/sync-frame-shared.test.ts apps/bilig/src/workbook-runtime/sync-frame-router.test.ts apps/bilig/src/workbook-runtime/workbook-sync-session-host.test.ts",
    "test:correctness:fast": "pnpm analyze:quality && pnpm test:correctness:core && pnpm test:correctness:formula && pnpm test:correctness:corpus && pnpm test:correctness:server",
    "test:correctness:medium": "pnpm test:correctness:fast && pnpm test:correctness:browser",
    "test:correctness:deep": "bun scripts/clean-package-builds.ts && pnpm build && pnpm test:correctness:medium && pnpm test:fuzz:main && pnpm bench:smoke && CI=1 pnpm bench:contracts",
    "test:watch": "bun scripts/run-vitest.ts",
    "bench": "pnpm --filter @bilig/benchmarks bench",
    "bench:workpaper": "tsx packages/benchmarks/src/benchmark-workpaper.ts",
    "bench:workpaper:competitive": "tsx packages/benchmarks/src/benchmark-workpaper-vs-hyperformula-expanded.ts",
    "bench:smoke": "bun scripts/perf-smoke.ts",
    "bench:contracts": "bun scripts/bench-contracts.ts",
    "workpaper:parity:generate": "bun scripts/gen-workpaper-hyperformula-audit.ts",
    "workpaper:parity:check": "bun scripts/gen-workpaper-hyperformula-audit.ts --check",
    "workpaper:bench:generate": "bun scripts/gen-workpaper-benchmark-baseline.ts",
    "workpaper:bench:check": "bun scripts/gen-workpaper-benchmark-baseline.ts --check",
    "workpaper:bench:competitive:generate": "bun scripts/gen-workpaper-vs-hyperformula-benchmark.ts",
    "workpaper:bench:competitive:check": "bun scripts/gen-workpaper-vs-hyperformula-benchmark.ts --check",
    "workpaper:xlsx-corpus:fixtures:generate": "bun scripts/gen-workpaper-xlsx-corpus-fixtures.ts",
    "workpaper:xlsx-corpus:fixtures:check": "bun scripts/gen-workpaper-xlsx-corpus-fixtures.ts --check && pnpm workpaper:xlsx-corpus:check -- packages/headless/fixtures/xlsx-corpus",
    "workpaper:xlsx-corpus:check": "bun scripts/check-workpaper-xlsx-corpus.ts",
    "workpaper:smoke:external": "bun scripts/workpaper-external-smoke.ts",
    "publish:check": "bun scripts/clean-package-builds.ts && pnpm build && bun scripts/check-package-publish.ts",
    "publish:runtime:plan": "bun scripts/plan-runtime-release.ts",
    "publish:runtime:next-version": "bun scripts/next-runtime-release-version.ts",
    "publish:runtime:check": "bun scripts/check-package-publish.ts --require-aligned packages/protocol packages/workbook-domain packages/wasm-kernel packages/formula packages/core packages/excel-import packages/headless",
    "publish:runtime:sync-metadata": "bun scripts/sync-runtime-release-metadata.ts",
    "runtime:commit-policy": "bun scripts/check-runtime-commit-policy.ts",
    "publish:runtime": "bun scripts/publish-runtime-package-set.ts",
    "release:check": "bun scripts/release-check.ts",
    "wasm:build": "pnpm --filter @bilig/wasm-kernel build",
    "ci": "BILIG_CI_PROFILE=fast BILIG_CI_SKIP_BROWSER=1 bun scripts/run-ci.ts",
    "ci:core": "BILIG_CI_PROFILE=fast BILIG_CI_SKIP_BROWSER=1 bun scripts/run-ci.ts",
    "ci:browser": "pnpm --filter @bilig/app^... run build && VITE_BILIG_REMOTE_SYNC=0 pnpm --filter @bilig/web build:bundle && BILIG_BROWSER_CI_SMOKE=1 BILIG_DEV_APP_RUNTIME_BUILD=0 BILIG_DEV_WEB_PREVIEW_BUILD=0 pnpm test:browser",
    "ci:browser:full": "pnpm --filter @bilig/app^... run build && VITE_BILIG_REMOTE_SYNC=0 pnpm --filter @bilig/web build:bundle && BILIG_DEV_APP_RUNTIME_BUILD=0 BILIG_DEV_WEB_PREVIEW_BUILD=0 pnpm test:browser:full",
    "ci:full": "BILIG_CI_PROFILE=full bun scripts/run-ci.ts"
  },
  "devDependencies": {
    "@bilig/test-fuzz": "workspace:*",
    "@playwright/test": "1.58.2",
    "@types/node": "25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-reconciler": "^0.33.0",
    "@vitest/coverage-v8": "4.1.2",
    "dependency-cruiser": "^17.3.10",
    "fast-check": "4.6.0",
    "jsdom": "29.0.1",
    "knip": "^6.3.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.9",
    "vitest": "4.1.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm hooks:pre-commit",
    "pre-push": "pnpm hooks:pre-push"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,json,css,html}": [
      "oxfmt --write"
    ],
    "*.{js,cjs,mjs,jsx,ts,tsx}": [
      "oxlint --config .oxlintrc.json --type-aware --fix --deny-warnings"
    ]
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "defu": "6.1.7",
      "protobufjs": "7.5.5"
    }
  }
}
