{
  "name": "@bilig/playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js",
    "build": "tsc -p tsconfig.json && node ../../node_modules/vite/bin/vite.js build",
    "preview": "node ../../node_modules/vite/bin/vite.js preview",
    "preview:ci": "pnpm -w build && node ../../node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 4179 --strictPort"
  },
  "dependencies": {
    "@bilig/benchmarks": "workspace:*",
    "@bilig/binary-protocol": "workspace:*",
    "@bilig/core": "workspace:*",
    "@bilig/crdt": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/grid": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "@bilig/renderer": "workspace:*",
    "@bilig/storage-browser": "workspace:*",
    "@bilig/worker-transport": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "6.0.0"
  }
}
