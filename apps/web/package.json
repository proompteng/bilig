{
  "name": "@bilig/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/vite/bin/vite.js",
    "prebuild": "bun ../../scripts/gen-workspace-resolution.ts",
    "build": "tsc -b tsconfig.json && node ../../node_modules/vite/bin/vite.js build",
