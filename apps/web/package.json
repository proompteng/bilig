    "@bilig/benchmarks": "workspace:*",
    "@bilig/contracts": "workspace:*",
    "@bilig/core": "workspace:*",
    "@bilig/excel-import": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/grid": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "@bilig/runtime-kernel": "workspace:*",
    "@bilig/storage-browser": "workspace:*",
    "@bilig/workbook-domain": "workspace:*",
    "@bilig/worker-transport": "workspace:*",
    "@bilig/zero-sync": "workspace:*",
    "@hugeicons/core-free-icons": "4.1.1",
    "@hugeicons/react": "1.1.6",
    "@rocicorp/zero": "1.1.1",
    "@xstate/react": "6.1.0",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "effect": "3.21.0",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "xstate": "5.30.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "^4.2.2"
  }
