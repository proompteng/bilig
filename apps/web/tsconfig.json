{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "paths": {
      "@bilig/actors": ["../../packages/actors/src/index.ts"],
      "@bilig/agent-api": ["../../packages/agent-api/src/index.ts"],
      "@bilig/benchmarks": ["../../packages/benchmarks/src/index.ts"],
      "@bilig/binary-protocol": ["../../packages/binary-protocol/src/index.ts"],
      "@bilig/contracts": ["../../packages/contracts/src/index.ts"],
      "@bilig/core": ["../../packages/core/src/index.ts"],
      "@bilig/excel-import": ["../../packages/excel-import/src/index.ts"],
      "@bilig/formula": ["../../packages/formula/src/index.ts"],
      "@bilig/grid": ["../../packages/grid/src/index.ts"],
      "@bilig/protocol": ["../../packages/protocol/src/index.ts"],
      "@bilig/renderer": ["../../packages/renderer/src/index.ts"],
      "@bilig/runtime-kernel": ["../../packages/runtime-kernel/src/index.ts"],
      "@bilig/storage-browser": ["../../packages/storage-browser/src/index.ts"],
      "@bilig/workbook-domain": ["../../packages/workbook-domain/src/index.ts"],
      "@bilig/worker-transport": ["../../packages/worker-transport/src/index.ts"],
      "@bilig/zero-sync": ["../../packages/zero-sync/src/index.ts"]
    },
    "types": ["vite/client"],
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "references": [
    { "path": "../../packages/agent-api" },
    { "path": "../../packages/actors" },
    { "path": "../../packages/binary-protocol" },
    { "path": "../../packages/contracts" },
    { "path": "../../packages/core" },
    { "path": "../../packages/excel-import" },
    { "path": "../../packages/formula" },
    { "path": "../../packages/grid" },
    { "path": "../../packages/protocol" },
    { "path": "../../packages/runtime-kernel" },
    { "path": "../../packages/storage-browser" },
    { "path": "../../packages/worker-transport" },
    { "path": "../../packages/workbook-domain" },
    { "path": "../../packages/zero-sync" },
    { "path": "../../packages/test-fuzz" }
  ],
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/__tests__/**"]
}
