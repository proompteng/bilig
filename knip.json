{
  "$schema": "./node_modules/knip/schema.json",
  "rules": {
    "types": "off"
  },
  "ignoreIssues": {
    "packages/grid/src/useViewport.ts": ["duplicates"],
    "packages/wasm-kernel/assembly/**/*.ts": ["exports", "enumMembers"]
  },
  "workspaces": {
    ".": {
      "ignoreFiles": ["**/__tests__/**", "**/*.test.ts?(x)", "e2e/**", "scripts/**", "playwright.config.ts", "playwright.prod.config.ts"],
      "entry": ["e2e/tests/prod-smoke.pw.ts", "scripts/bench-worker-runtime.ts"]
    },
    "packages/wasm-kernel": {
      "entry": ["assembly/index.ts"],
      "project": ["assembly/**/*.ts"],
      "ignoreDependencies": ["assemblyscript"]
    }
  }
}
