    "name": "Greg Konush",
    "email": "12027037+gregkonush@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "integrations/n8n-nodes-workpaper"
  },
