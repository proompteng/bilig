{
  "targets": {
    "debug": {
      "bindings": "esm",
      "debug": true,
      "sourceMap": true,
      "optimizeLevel": 0,
      "shrinkLevel": 0,
      "runtime": "incremental",
      "outFile": "build/debug.wasm"
    },
    "release": {
      "bindings": "esm",
      "debug": false,
      "sourceMap": false,
      "optimizeLevel": 3,
      "shrinkLevel": 1,
      "converge": true,
      "noAssert": true,
      "runtime": "incremental",
      "outFile": "build/release.wasm"
    }
  }
}
