{
  "name": "@bilig/benchmarks",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generate-workbook": {
      "types": "./dist/generate-workbook.d.ts",
      "import": "./dist/generate-workbook.js"
    }
  },
  "dependencies": {
    "@bilig/core": "workspace:*",
    "@bilig/protocol": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bench": "tsx src/index.ts"
  },
  "description": "Benchmark scenarios, metrics helpers, and workbook generators for bilig.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/benchmarks"
  },
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/benchmarks#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "keywords": [
    "bilig",
    "benchmark",
    "performance",
    "spreadsheet"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
