{
  "name": "@bilig/core",
  "version": "0.1.0",
  "description": "Local-first spreadsheet engine core for bilig with calc, selection, and commit semantics.",
  "keywords": [
    "bilig",
    "engine",
    "formula",
    "local-first",
    "spreadsheet"
  ],
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "@bilig/wasm-kernel": "workspace:*",
    "@bilig/workbook-domain": "workspace:*",
    "effect": "3.21.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
