      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@bilig/core": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "typegpu": "0.11.2"
  },
  "devDependencies": {
    "@types/react-dom": "19.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
