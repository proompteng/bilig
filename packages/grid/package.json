{
  "name": "@bilig/grid",
  "version": "0.1.0",
  "description": "Excel-like React workbook grid surfaces and overlays for bilig.",
  "keywords": [
    "bilig",
    "excel",
    "grid",
    "react",
    "spreadsheet"
  ],
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/grid#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/grid"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
