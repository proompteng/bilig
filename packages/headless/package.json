{
  "name": "@bilig/headless",
  "version": "0.40.40",
  "description": "Formula WorkPaper runtime for Node.js services and agent tools with JSON persistence and formula readback.",
  "keywords": [
    "agent-tools",
    "ai-agents",
    "excel",
    "excel-formulas",
    "exceljs",
    "formula-engine",
    "formula-recalculation",
    "headless-spreadsheet",
    "hyperformula",
    "mcp",
    "mcp-server",
    "node",
    "sheetjs",
    "spreadsheet-agent",
    "spreadsheet-automation",
    "spreadsheet-engine",
    "spreadsheet-formulas",
    "spreadsheet-mcp",
    "typescript",
    "workbook-agent",
    "workbook-api",
    "workpaper",
    "xlsx",
    "xlsx-calc"
  ],
  "homepage": "https://proompteng.github.io/bilig/",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/headless"
  },
  "bin": {
    "bilig-agent-challenge": "./dist/agent-workbook-challenge-bin.js",
    "bilig-formula-clinic": "./dist/formula-clinic-bin.js",
    "bilig-mcp-challenge": "./dist/mcp-challenge-bin.js",
    "bilig-workpaper-mcp": "./dist/work-paper-mcp-stdio-bin.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "SKILL.md",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./xlsx": {
      "types": "./dist/xlsx.d.ts",
      "import": "./dist/xlsx.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --dir ../.. --filter @bilig/excel-import build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && bun ../../scripts/build-headless-xlsx-subpath.ts"
  },
  "dependencies": {
    "@bilig/core": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "fast-xml-parser": "5.7.3",
    "fflate": "0.3.11",
    "fflate-stream": "npm:fflate@0.8.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xlsx-js-style": "1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "mcpName": "io.github.proompteng/bilig-workpaper"
}
