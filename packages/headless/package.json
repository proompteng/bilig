{
  "name": "@bilig/headless",
  "version": "0.16.1",
  "description": "Formula WorkPaper runtime for Node.js services and agent tools with JSON persistence and formula readback.",
  "keywords": [
    "agent",
    "agent-tools",
    "ai-sdk",
    "bilig",
    "excel",
    "formula",
    "formula-engine",
    "formula-evaluation",
    "headless-spreadsheet",
    "headless-workbook",
    "hyperformula",
    "json-persistence",
    "mcp",
    "model-context-protocol",
    "node",
    "nodejs",
    "spreadsheet-formulas",
    "typescript",
    "vercel-ai-sdk",
    "workbook",
    "workbook-api",
    "workbook-state",
    "workpaper",
    "xlsx"
  ],
  "homepage": "https://proompteng.github.io/bilig/",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/headless"
  },
  "bin": {
    "bilig-workpaper-mcp": "./dist/work-paper-mcp-stdio-bin.js"
  },
  "files": [
    "dist",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./xlsx": {
      "types": "./dist/xlsx.d.ts",
      "import": "./dist/xlsx.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --dir ../.. --filter @bilig/excel-import build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json && bun ../../scripts/build-headless-xlsx-subpath.ts"
  },
  "dependencies": {
    "@bilig/core": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*",
    "fast-xml-parser": "5.7.3",
    "fflate": "0.3.11",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xlsx-js-style": "1.2.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "mcpName": "io.github.proompteng/bilig-workpaper"
}
