{
  "name": "@bilig/headless",
  "version": "0.1.95",
  "description": "Headless spreadsheet engine and WorkPaper workbook facade for Node services, coding agents, and HyperFormula-style workflows.",
  "keywords": [
    "agent",
    "automation",
    "bilig",
    "formula",
    "formula-engine",
    "headless",
    "headless-spreadsheet",
    "hyperformula",
    "local-first",
    "node",
    "spreadsheet",
    "spreadsheet-engine",
    "workbook"
  ],
  "homepage": "https://github.com/proompteng/bilig/tree/main/packages/headless#readme",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/headless"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@bilig/core": "workspace:*",
    "@bilig/formula": "workspace:*",
    "@bilig/protocol": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
