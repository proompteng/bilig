{
  "name": "@bilig/xlsx-formula-recalc",
  "version": "0.40.31",
  "description": "Scoped XLSX formula recalculation package for Node.js without Excel, LibreOffice, or browser automation.",
  "keywords": [
    "bilig",
    "excel",
    "excel-formulas",
    "formula-engine",
    "formula-recalculation",
    "node",
    "sheetjs",
    "spreadsheet",
    "spreadsheet-formulas",
    "workbook",
    "xlsx",
    "xlsx-calc",
    "xlsx-formula",
    "xlsx-formula-recalculation",
    "xlsx-recalc",
    "xlsx-recalculation"
  ],
  "homepage": "https://proompteng.github.io/bilig/xlsx-formula-recalculation-node.html",
  "bugs": {
    "url": "https://github.com/proompteng/bilig/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proompteng/bilig.git",
    "directory": "packages/bilig-xlsx-formula-recalc"
  },
  "bin": {
    "sheetjs-recalc": "./dist/sheetjs-cli.js",
    "xlsx-recalc": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli-api": {
      "types": "./dist/cli-api.d.ts",
      "import": "./dist/cli-api.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm --dir ../.. --filter xlsx-formula-recalc build && rm -rf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "smoke": "node ./dist/cli.js --help"
  },
  "dependencies": {
    "xlsx-formula-recalc": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
